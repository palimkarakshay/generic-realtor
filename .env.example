# ============================================================
# Generic Realtor Marketing Site — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# v1 default: ALL services are free-tier with no credit card.

# --- Site basics (required) ---
NEXT_PUBLIC_SITE_URL=https://yourdomain.ca
NEXT_PUBLIC_SITE_NAME="Realtor Name"

# --- Resend email (free tier: 100 emails/day) ---
# Get key at https://resend.com/api-keys after verifying your domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@yourdomain.ca
RESEND_TO_EMAIL=your-personal-gmail@gmail.com

# --- Cloudflare Turnstile (free, no credit card) ---
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x0000000000000000000000
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# --- Cloudflare Web Analytics (free, optional) ---
# https://dash.cloudflare.com/?to=/:account/web-analytics
NEXT_PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=

# --- Calendly (free tier) ---
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/intro

# --- Google Sheets lead-log webhook (Apps Script) ---
# Deploy an Apps Script as a Web App that appends a row to your Sheet.
# Free, no third-party SaaS. Leave blank to disable.
GOOGLE_SHEETS_WEBHOOK_URL=

# --- Decap CMS admin (GitHub OAuth, free) ---
# Only required if using the /admin CMS. Free GitHub OAuth app.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Optional v1.5+ upgrades (leave blank in v1) ---
# Twilio SMS speed-to-lead (~$2/mo)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Follow Up Boss CRM ($69/mo)
FUB_API_KEY=
# Mapbox (free tier requires CC — Leaflet+OSM is the v1 default)
NEXT_PUBLIC_MAPBOX_TOKEN=
